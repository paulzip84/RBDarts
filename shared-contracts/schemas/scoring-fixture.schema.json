{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rbdarts.local/schemas/scoring-fixture.schema.json",
  "title": "RBDarts scoring fixture",
  "type": "object",
  "required": ["name", "regulationInnings", "extraInningsEnabled", "participants", "expected"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "regulationInnings": { "type": "integer", "minimum": 1, "default": 9 },
    "extraInningsEnabled": { "type": "boolean" },
    "post20TieRule": { "enum": ["repeat20", "restartAt1", "bullseyeTiebreaker"] },
    "dartsPerTurn": { "type": "integer", "const": 3 },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "displayName"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["player", "team"] },
          "teamId": { "type": "string" },
          "playerIds": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "lineupOrder": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "average": { "type": "number", "minimum": 0 },
          "scores": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "minimum": 0, "maximum": 9 }
          }
        }
      }
    },
    "turns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "inning", "target", "participantId", "playerId", "darts"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "inning": { "type": "integer", "minimum": 1 },
          "target": { "type": "integer", "minimum": 1, "maximum": 25 },
          "participantId": { "type": "string", "minLength": 1 },
          "teamId": { "type": ["string", "null"] },
          "playerId": { "type": "string", "minLength": 1 },
          "darts": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "object",
              "required": ["index", "target", "ring", "validity", "score"],
              "properties": {
                "index": { "type": "integer", "minimum": 1, "maximum": 3 },
                "target": { "type": "integer", "minimum": 1, "maximum": 25 },
                "landedNumber": { "type": ["integer", "null"], "minimum": 1, "maximum": 25 },
                "ring": { "enum": ["miss", "single", "double", "triple", "outerBull", "innerBull"] },
                "validity": { "enum": ["valid", "wrongNumber", "bounceOut", "fellOut", "foulLine", "outOfTurn"] },
                "score": { "type": "integer", "minimum": 0, "maximum": 3 }
              }
            }
          }
        }
      }
    },
    "expected": {
      "type": "object",
      "required": ["totals", "winnerIds", "margin", "inningsPlayed"],
      "properties": {
        "totals": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "winnerIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "margin": { "type": "integer", "minimum": 0 },
        "inningsPlayed": { "type": "integer", "minimum": 1 },
        "needsExtraInning": { "type": "boolean" },
        "currentTarget": { "type": "integer", "minimum": 1, "maximum": 25 }
      }
    }
  }
}

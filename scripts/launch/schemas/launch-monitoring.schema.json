{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rbdarts.app/schemas/launch-monitoring.schema.json",
  "title": "Launch Monitoring Plan",
  "type": "object",
  "required": ["monitoringPlanId", "signals", "thresholds", "reviewCadence", "supportOwner", "engineeringOwner", "escalationPath", "hotfixCriteria", "rollbackCriteria"],
  "properties": {
    "monitoringPlanId": { "type": "string" },
    "signals": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "thresholds": { "type": "object" },
    "reviewCadence": { "type": "string" },
    "supportOwner": { "type": "string" },
    "engineeringOwner": { "type": "string" },
    "escalationPath": { "type": "string" },
    "hotfixCriteria": { "type": "string" },
    "rollbackCriteria": { "type": "string" }
  }
}
